<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- TV feature declarations -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <application
        android:name=".IPTVApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.IPTVAutoCombine"
        android:networkSecurityConfig="@xml/network_security_config"
        android:banner="@drawable/tv_banner"
        tools:targetApi="34">

        <!-- Mobile/Tablet Main Activity -->
        <activity
            android:name=".ui.mobile.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.IPTVAutoCombine">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Mobile/Tablet Player Activity -->
        <activity
            android:name=".ui.mobile.PlayerActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.IPTVAutoCombine.Player" />

        <!-- TV Main Activity -->
        <activity
            android:name=".ui.tv.TVMainActivity"
            android:exported="true"
            android:theme="@style/Theme.IPTVAutoCombine.TV">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- TV Player Activity -->
        <activity
            android:name=".ui.tv.TVPlayerActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.IPTVAutoCombine.TV" />

        <!-- Settings Activity -->
        <activity
            android:name=".ui.mobile.SettingsActivity"
            android:theme="@style/Theme.IPTVAutoCombine"
            android:parentActivityName=".ui.mobile.MainActivity" />

        <!-- Playlist Refresh Worker -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge" />

    </application>

</manifest>
