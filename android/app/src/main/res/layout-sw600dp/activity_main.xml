<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/gradient_background"
    tools:context=".ui.mobile.MainActivity">

    <!-- Left pane: Channel list -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Bottom Navigation -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_navigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_dark_1"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_nav_menu"
            style="@style/Widget.IPTVAutoCombine.BottomNav" />
    </LinearLayout>

    <!-- Right pane: Player -->
    <FrameLayout
        android:id="@+id/tablet_player_container"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@color/player_background"
        android:visibility="gone">

        <androidx.media3.ui.PlayerView
            android:id="@+id/tablet_player_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:show_buffering="when_playing"
            app:use_controller="true"
            app:resize_mode="fit" />

        <!-- Channel info overlay -->
        <LinearLayout
            android:id="@+id/tablet_channel_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/player_overlay_gradient"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tablet_channel_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tablet_channel_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
