<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/channel_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/card_margin"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation"
    app:cardBackgroundColor="@color/card_background"
    app:rippleColor="@color/card_ripple"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/card_padding">

        <!-- Channel Logo -->
        <androidx.cardview.widget.CardView
            android:layout_width="@dimen/channel_logo_size"
            android:layout_height="@dimen/channel_logo_size"
            app:cardCornerRadius="@dimen/channel_logo_radius"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface_dark_3">

            <ImageView
                android:id="@+id/channel_logo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="@string/content_description_logo"
                tools:src="@drawable/channel_placeholder" />
        </androidx.cardview.widget.CardView>

        <!-- Channel Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/channel_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.IPTVAutoCombine.ChannelTitle"
                tools:text="BBC One HD" />

            <TextView
                android:id="@+id/channel_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                style="@style/TextAppearance.IPTVAutoCombine.ChannelSubtitle"
                tools:text="🇬🇧 United Kingdom" />
        </LinearLayout>

        <!-- Favorite button -->
        <ImageButton
            android:id="@+id/favorite_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/btn_star_big_off"
            android:contentDescription="@string/content_description_favorite"
            android:padding="8dp"
            android:scaleType="fitCenter" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
